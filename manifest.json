{
  "manifest_version": 3,
  "name": "WooCommerce Scraper",
  "version": "1.0",
  "description": "Scraper voor WooCommerce Back In Stock meldingen",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WooCommerce Scraper"
  }
}
